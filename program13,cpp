#include<iostream>
using namespace std;
int main()
{
    int x;
    cin>>x;
    if(x>0 && x<=10)
    {
        int arr[x];
        for(int i=0;i<x;i++)
        {
            cin>>arr[i];
        }
        int p=arr[0];
        for(int j=0;j<x;j++)
        {
            if(p<arr[j])
            {
                p=arr[j];
            }
        }
        cout<<"Max:"<<p<<endl;
        int l=arr[0];
        for(int k=0;k<x;k++)
        {
            if(l>arr[k])
            {
                l=arr[k];
            }
        }
        cout<<"Min:"<<l<<endl;
    }
    else
    {
        cout<<"Invalid"<<endl;
    }

    
}
